{
  "name": "bag-reconciliation-tool",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:client && npm run copy:client",
    "build:client": "npm run --prefix packages/client build",
    "build:server": "npm run --prefix packages/server build",
    "copy:client": "mkdir -p packages/server/dist/public && cp -r packages/client/dist/* packages/server/dist/public/",
    "start": "node packages/server/dist/server.js",
    "dev:server": "npm run --prefix packages/server dev",
    "dev:client": "npm run --prefix packages/client dev",
    "test": "npm run test --workspaces --if-present",
    "test:server": "npm run --prefix packages/server test"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
