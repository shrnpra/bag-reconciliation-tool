# Database
# PostgreSQL connection string (auto-injected by Railway Postgres plugin in production)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET="your-jwt-secret-here"

# Application
NODE_ENV="development"

# Server port (auto-injected by Railway in production)
PORT=3000
